{
  "$schema": "drip-team-v1",
  "version": "1.0.0",
  "template": "team-page",

  "themes": {
    "dark": {
      "bg": "#0C0C0E", "surface": "#16161A", "surface-alt": "#1C1C21", "surface-raised": "#222228",
      "text-1": "#EDEDEC", "text-2": "#A0A09A", "text-3": "#6B6B65", "text-4": "#3E3E3A",
      "rule": "#2A2A2E", "rule-dim": "#1F1F23", "rule-hair": "rgba(255,255,255,.04)",
      "hover": "rgba(255,255,255,.02)", "best-bg": "rgba(255,255,255,.04)",
      "backdrop": "rgba(12,12,14,.85)"
    },
    "light": {
      "bg": "#F5F4F1", "surface": "#FFFFFF", "surface-alt": "#FAF9F7", "surface-raised": "#F0EFEC",
      "text-1": "#18181B", "text-2": "#52524E", "text-3": "#8C8C84", "text-4": "#BBBBB3",
      "rule": "#E6E5E1", "rule-dim": "#EDECE9", "rule-hair": "rgba(0,0,0,.035)",
      "hover": "rgba(0,0,0,.015)", "best-bg": "rgba(0,0,0,.035)",
      "backdrop": "rgba(245,244,241,.82)"
    }
  },

  "layout": {
    "max-width": "1060px",
    "side-padding": "28px",
    "mobile-padding": "20px"
  },

  "components": {

    "team-hero": {
      "padding": "28px 28px 20px",
      "gap": "24px",
      "phone-gap": "16px",
      "logo": {
        "size": "80px",
        "phone-size": "60px",
        "radius": "14px",
        "phone-radius": "10px",
        "team-bar": { "height": "3px", "inset": "16px", "color": "--team-color with fallback" }
      },
      "name": {
        "font": "display",
        "size": "1.75rem",
        "phone-size": "1.375rem",
        "weight": 800,
        "tracking": "-0.05em"
      },
      "meta": {
        "font": "mono",
        "size": "0.5625rem",
        "color": "text-3",
        "format": "league · division rank · home venue"
      },
      "record-strip": {
        "container": { "bg": "surface", "border": "rule", "radius": "6px" },
        "stat": {
          "value": { "font": "mono", "size": "1rem", "phone-size": "0.875rem", "weight": 500 },
          "label": { "font": "mono", "size": "0.375rem", "color": "text-4", "uppercase": true, "tracking": "0.06em" }
        },
        "fields": ["record", "pct", "gb", "streak", "diff", "l10"]
      }
    },

    "tabs": {
      "items": ["Schedule", "Roster", "Trends"],
      "font": "mono",
      "size": "0.5625rem",
      "weight": 500,
      "inactive": { "color": "text-4" },
      "active": { "color": "text-1", "border-bottom": "2px solid text-1" },
      "sticky": true,
      "sticky-offset": "47px"
    },

    "schedule-tab": {
      "layout": {
        "desktop": "1fr 280px",
        "tablet": "1fr",
        "gap": { "desktop": "24px", "tablet": "14px" }
      },

      "results-strip": {
        "scrollable": true,
        "gap": "4px",
        "phone-gap": "3px",
        "game": {
          "min-width": "44px",
          "phone-min-width": "38px",
          "bg": "surface",
          "border": "rule-hair",
          "radius": "4px"
        },
        "result": {
          "font": "mono",
          "size": "0.5rem",
          "weight": 500,
          "win": "text-1",
          "loss": "text-4"
        },
        "score": { "font": "mono", "size": "0.5625rem", "color": "text-2" },
        "opponent": { "font": "mono", "size": "0.375rem", "color": "text-4" }
      },

      "schedule-card": {
        "bg": "surface",
        "border": "rule",
        "radius": "8px",
        "row": {
          "grid": {
            "desktop": "56px 28px 1fr 80px 60px",
            "phone": "44px 22px 1fr 60px"
          },
          "padding": "7px 16px",
          "hover": "hover token"
        },
        "date": { "font": "mono", "size": "0.5625rem", "color": "text-3", "upcoming-color": "text-2" },
        "logo": { "size": "18px", "radius": "3px" },
        "opponent": { "font": "body", "size": "0.75rem", "weight": 600 },
        "home-away": { "font": "mono", "size": "0.4375rem", "color": "text-4" },
        "result": {
          "font": "mono", "size": "0.6875rem", "weight": 500,
          "win": "text-1", "loss": "text-4"
        },
        "time": { "font": "mono", "size": "0.5625rem", "color": "text-3" },
        "record-running": { "font": "mono", "size": "0.4375rem", "color": "text-4" },
        "probable-starter": { "font": "mono", "size": "0.4375rem", "color": "text-3" },
        "past-upcoming-divider": "2px solid rule-dim"
      },

      "sidebar": {
        "sections": [
          {
            "id": "division",
            "label": "Division",
            "rows": "dynamic — 5 teams with record and GB"
          },
          {
            "id": "next-series",
            "label": "Next Series",
            "fields": ["Opponent", "Dates", "Season series"]
          },
          {
            "id": "splits",
            "label": "Splits",
            "fields": ["Home", "Away", "vs Division", "1-run games", "Extra innings"]
          }
        ]
      }
    },

    "roster-tab": {
      "layout": {
        "desktop": "1fr 1fr",
        "tablet": "1fr",
        "gap": "14px"
      },
      "groups": ["Position Players", "Pitchers"],
      "group-card": {
        "bg": "surface",
        "border": "rule",
        "radius": "8px",
        "header": {
          "title": { "font": "display", "size": "0.75rem", "weight": 800, "tracking": "-0.03em" },
          "count": { "font": "mono", "size": "0.4375rem", "color": "text-4" }
        }
      },
      "player-row": {
        "grid": "24px 1fr auto auto",
        "padding": "5px 14px",
        "hover": "hover token",
        "photo": { "size": "20px", "radius": "50%" },
        "name": { "font": "body", "size": "0.6875rem", "weight": 600, "truncate": true },
        "number": { "font": "mono", "size": "0.5rem", "color": "text-4", "align": "right" },
        "stat": {
          "font": "mono", "size": "0.5625rem", "color": "text-3", "align": "right",
          "batter-format": ".AVG / HR HR",
          "pitcher-format": "ERA ERA · W-L"
        }
      }
    },

    "trends-tab": {
      "layout": {
        "desktop": "1fr 1fr",
        "tablet": "1fr",
        "gap": "14px"
      },
      "cards": [
        {
          "id": "moneyline",
          "title": "Moneyline Record",
          "fields": [
            { "key": "Overall", "emphasis": true },
            { "key": "As favorite", "emphasis": true },
            { "key": "As underdog", "emphasis": false },
            { "key": "Last 10 as fav", "emphasis": true }
          ]
        },
        {
          "id": "over-under",
          "title": "Over/Under",
          "fields": [
            { "key": "Overall", "emphasis": true },
            { "key": "Home", "emphasis": true },
            { "key": "Away", "emphasis": false },
            { "key": "Over %", "emphasis": true }
          ],
          "has-bar": true,
          "bar-field": "Over %"
        },
        {
          "id": "run-line",
          "title": "Run Line (-1.5)",
          "fields": [
            { "key": "Overall", "emphasis": true },
            { "key": "Home", "emphasis": true },
            { "key": "Away", "emphasis": false },
            { "key": "Cover %", "emphasis": false }
          ],
          "has-bar": true,
          "bar-field": "Cover %"
        },
        {
          "id": "situational",
          "title": "Situational",
          "fields": [
            { "key": "Day games", "emphasis": false },
            { "key": "Night games", "emphasis": true },
            { "key": "After a loss", "emphasis": true },
            { "key": "3+ day rest", "emphasis": false },
            { "key": "vs .500+ teams", "emphasis": true }
          ]
        }
      ],
      "card-spec": {
        "bg": "surface",
        "border": "rule",
        "radius": "8px",
        "padding": "14px 16px",
        "title": { "font": "display", "size": "0.75rem", "weight": 800, "tracking": "-0.03em" },
        "row-key": { "font": "body", "size": "0.6875rem", "weight": 600, "color": "text-2" },
        "row-value": {
          "font": "mono", "size": "0.75rem", "weight": 500,
          "emphasis": "text-1",
          "dim": "text-3"
        },
        "bar": {
          "height": "4px",
          "radius": "2px",
          "track": "rule-dim",
          "fill": "text-2"
        }
      }
    }
  },

  "data-binding": {
    "team": {
      "teamId": "string",
      "abbr": "string",
      "name": "string",
      "fullName": "string",
      "logoUrl": "string",
      "primaryColor": "string",
      "league": "string",
      "division": "string",
      "divisionRank": "number",
      "venue": "string",
      "record": {
        "wins": "number",
        "losses": "number",
        "pct": "string",
        "gb": "string",
        "streak": "string",
        "runDiff": "number",
        "last10": "string"
      },
      "recentGames": [
        {
          "date": "string",
          "opponent": { "abbr": "string", "logoUrl": "string" },
          "homeAway": "home | away",
          "result": "W | L",
          "score": "string",
          "runningRecord": "string"
        }
      ],
      "upcomingGames": [
        {
          "date": "string",
          "opponent": { "abbr": "string", "name": "string", "logoUrl": "string" },
          "homeAway": "home | away",
          "time": "string",
          "probableStarter": "string | null"
        }
      ],
      "division": {
        "teams": [
          {
            "abbr": "string",
            "record": "string",
            "gb": "string"
          }
        ]
      },
      "nextSeries": {
        "opponent": "string",
        "dates": "string",
        "seasonSeries": "string"
      },
      "splits": {
        "home": "string",
        "away": "string",
        "vsDivision": "string",
        "oneRun": "string",
        "extras": "string"
      },
      "roster": {
        "positionPlayers": [
          {
            "playerId": "string",
            "name": "string",
            "number": "number",
            "photoUrl": "string",
            "stat": "string"
          }
        ],
        "pitchers": [
          {
            "playerId": "string",
            "name": "string",
            "number": "number",
            "photoUrl": "string",
            "stat": "string"
          }
        ]
      },
      "trends": {
        "moneyline": {
          "overall": "string",
          "asFavorite": "string",
          "asUnderdog": "string",
          "last10AsFav": "string"
        },
        "overUnder": {
          "overall": "string",
          "home": "string",
          "away": "string",
          "overPct": "string"
        },
        "runLine": {
          "overall": "string",
          "home": "string",
          "away": "string",
          "coverPct": "string"
        },
        "situational": {
          "dayGames": "string",
          "nightGames": "string",
          "afterLoss": "string",
          "rest3Plus": "string",
          "vs500Plus": "string"
        }
      }
    }
  }
}
