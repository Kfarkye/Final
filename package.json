{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "local:service": "WORKSPACE_ROOT=/Users/k.far.88/Developer/reverie ENGINEERING_WRITE_MODE=audit GCP_PROJECT=${GCP_PROJECT:-gen-lang-client-0281999829} OPENAI_API_KEY_SECRET=${OPENAI_API_KEY_SECRET:-OPENAI_API_KEY} CODEX_MAX_TOTAL_RESPONSE_TOKENS=${CODEX_MAX_TOTAL_RESPONSE_TOKENS:-10000000} tsx server.ts",
    "scrape:espn": "ts-node src/scraper/espn.ts",
    "fetch:repo": "bash scripts/fetch-public-repo.sh",
    "git:audit-large": "bash scripts/git-audit-large-files.sh 25 all",
    "git:audit-staged": "bash scripts/git-audit-large-files.sh 25 staged",
    "predeploy:check": "bash scripts/predeploy-check.sh",
    "repo:search": "rg -n \"Working|seconds|trace|web search|webSearch|searchUrl|toolCall|fetch|clone\" .",
    "code-memory:index": "tsx scripts/code-memory-index.ts",
    "code-memory:search": "tsx scripts/code-memory-search.ts",
    "code-memory:health": "tsx scripts/code-memory-health.ts",
    "build": "vite build && node scripts/build-server.mjs && npm --prefix mcp-servers/mcp-linear-ts install && npm --prefix mcp-servers/mcp-linear-ts run build && npm --prefix mcp-servers/mcp-notebook-ts install && npm --prefix mcp-servers/mcp-notebook-ts run build && npm --prefix mcp-servers/mcp-design-system-ts install && npm --prefix mcp-servers/mcp-design-system-ts run build",
    "chrome-bridge:validate": "node scripts/validate-truth-chrome-bridge.mjs",
    "start": "node dist/server.cjs",
    "build:ingest": "esbuild src/ingest-server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/ingest-server.cjs",
    "start:ingest": "node dist/ingest-server.cjs",
    "db:push": "npx drizzle-kit push --config=src/db/drizzle.config.ts --force",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run --reporter=verbose",
    "test:codex-quality": "vitest run src/codex/__tests__/codex-quality-harness.test.ts src/codex/__tests__/codex-handler.test.ts --reporter=verbose",
    "test:watch": "vitest --reporter=verbose",
    "deploy": "bash scripts/ship-run.sh",
    "deploy:legacy-gke": "gcloud builds submit --tag us-central1-docker.pkg.dev/gen-lang-client-0281999829/truth/reverie:latest . && kubectl apply -f k8s/ && kubectl rollout restart deployment/reverie && kubectl rollout status deployment/reverie --timeout=300s",
    "verify:contracts": "tsx src/hub/__tests__/verify-contracts.ts",
    "verify:deploy": "npm run verify:contracts && npm run chrome-bridge:validate && tsc --noEmit",
    "predeploy": "npm run verify:deploy"
  },
